{
  "name": "valor-cli",
  "version": "0.1.0",
  "description": "ValorIDE CLI agent for autonomous coding tasks",
  "main": "dist/index.js",
  "bin": {
    "valor": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src",
    "lint": "eslint src"
  },
  "keywords": [
    "agentic",
    "coding",
    "cli",
    "valoride"
  ],
  "author": "Valkyr Labs Inc.",
  "license": "Apache-2.0",
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "12.1.0",
    "execa": "8.0.1",
    "glob": "13.0.0",
    "ora": "8.2.0",
    "p-wait-for": "5.0.2",
    "serialize-error": "11.0.3",
    "uuid": "9.0.1",
    "yaml": "2.8.1"
  },
  "devDependencies": {
    "@types/node": "20.19.24",
    "@types/uuid": "9.0.8",
    "eslint": "8.57.1",
    "prettier": "3.6.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "1.6.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
