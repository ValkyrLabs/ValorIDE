diff --git a/src/api/providers/google-gemini.ts b/src/api/providers/google-gemini.ts
new file mode 100644
index 0000000..b86f2fe
--- /dev/null
+++ b/src/api/providers/google-gemini.ts
@@ -0,0 +1,303 @@
+/* eslint-disable @typescript-eslint/no-explicit-any */
+/**
+ * Google Gemini provider for ValorIDE (Cline fork)
+ * Supports Gemini 3, including thinking_level and mediaResolution.
+ * Streaming via @google/genai generateContentStream.
+ *
+ * Notes:
+ * - Thought signatures are automatically propagated by the official SDK
+ *   but we defensively forward any found signatures for function-calling turns.
+ * - The interface matches the minimal subset used by other providers
+ *   (createChat + streamChat + tool/function calling).
+ */
+
+import { GoogleGenAI } from '@google/genai';
+
+export type ToolSchema = {
+  name: string;
+  description?: string;
+  parameters?: Record<string, any>; // JSONSchema
+};
+
+export type Message =
+  | { role: 'system'; content: string }
+  | { role: 'user'; content: string }
+  | { role: 'assistant'; content: string }
+  | { role: 'tool'; content: string; name?: string };
+
+export interface ChatRequest {
+  messages: Message[];
+  tools?: ToolSchema[];
+  temperature?: number;
+  maxTokens?: number;
+  images?: Array<{ mimeType: string; data: string /* base64 */ }>;
+  mediaResolution?: 'media_resolution_low' | 'media_resolution_medium' | 'media_resolution_high' | 'auto';
+  thinkingLevel?: 'low' | 'high';
+  stream?: boolean;
+}
+
+export interface StreamCallbacks {
+  onText: (text: string) => void;
+  onToolCall?: (name: string, args: any) => void;
+  onEnd?: () => void;
+  onError?: (err: Error) => void;
+}
+
+export interface GeminiConfig {
+  apiKey: string;
+  apiVersion?: 'v1' | 'v1beta' | 'v1alpha';
+  model?: string;
+  defaultThinkingLevel?: 'low' | 'high';
+  defaultMediaResolution?: ChatRequest['mediaResolution'];
+}
+
+function mapTools(tools: ToolSchema[] | undefined) {
+  if (!tools || tools.length === 0) return undefined;
+  return {
+    functionDeclarations: tools.map(t => ({
+      name: t.name,
+      description: t.description,
+      parameters: t.parameters ?? { type: 'object', properties: {}, additionalProperties: true },
+    })),
+  };
+}
+
+function mapMessages(messages: Message[], images?: ChatRequest['images'], mediaResolution?: ChatRequest['mediaResolution']) {
+  const contents: any[] = [];
+  const imageParts =
+    (images && images.length > 0)
+      ? images.map(img => ({
+          inlineData: {
+            mimeType: img.mimeType,
+            data: img.data,
+          },
+          ...(mediaResolution && mediaResolution !== 'auto'
+            ? { mediaResolution: { level: mediaResolution } }
+            : {}),
+        }))
+      : [];
+
+  for (const m of messages) {
+    const parts: any[] = [];
+
+    if (m.role === 'system') {
+      parts.push({ text: m.content });
+      contents.push({ role: 'system', parts });
+      continue;
+    }
+
+    if (m.role === 'user') {
+      parts.push({ text: m.content });
+      for (const p of imageParts) parts.push(p);
+      contents.push({ role: 'user', parts });
+      continue;
+    }
+
+    if (m.role === 'assistant') {
+      parts.push({ text: m.content });
+      contents.push({ role: 'model', parts });
+      continue;
+    }
+
+    if (m.role === 'tool') {
+      // Gemini expects tool (function) responses inside user role with functionResponse part.
+      parts.push({
+        functionResponse: {
+          name: m.name ?? 'tool',
+          response: { content: m.content },
+        },
+      });
+      contents.push({ role: 'user', parts });
+      continue;
+    }
+  }
+  return contents;
+}
+
+export class Gemini3Provider {
+  private client: GoogleGenAI;
+  private model: string;
+  private apiVersion: GeminiConfig['apiVersion'];
+  private defaultThinkingLevel: GeminiConfig['defaultThinkingLevel'];
+  private defaultMediaResolution: GeminiConfig['defaultMediaResolution'];
+
+  constructor(cfg: GeminiConfig) {
+    this.client = new GoogleGenAI({
+      apiKey: cfg.apiKey,
+      apiVersion: cfg.apiVersion ?? 'v1beta',
+    } as any);
+    this.model = cfg.model ?? 'gemini-3-pro-preview';
+    this.apiVersion = cfg.apiVersion ?? 'v1beta';
+    this.defaultThinkingLevel = cfg.defaultThinkingLevel ?? 'high';
+    this.defaultMediaResolution = cfg.defaultMediaResolution ?? 'auto';
+  }
+
+  async createChat(req: ChatRequest): Promise<string> {
+    const contents = mapMessages(req.messages, req.images, req.mediaResolution ?? this.defaultMediaResolution);
+    const resp = await this.client.models.generateContent({
+      model: this.model,
+      contents,
+      generationConfig: {
+        temperature: req.temperature ?? 1.0,
+        maxOutputTokens: req.maxTokens,
+        ...(req.thinkingLevel ? { thinkingLevel: req.thinkingLevel } : { thinkingLevel: this.defaultThinkingLevel }),
+      } as any,
+      tools: mapTools(req.tools),
+    } as any);
+
+    // Tool calls (functionCall) path
+    const candidate = (resp as any).candidates?.[0];
+    const parts = candidate?.content?.parts ?? [];
+    for (const p of parts) {
+      if (p.functionCall) {
+        // Return a structured payload upstream or throw to let the agent handle it.
+        return JSON.stringify({ tool: p.functionCall.name, arguments: p.functionCall.args ?? {} });
+      }
+    }
+
+    return (resp as any).text ?? candidate?.content?.parts?.map((p: any) => p.text).join('') ?? '';
+  }
+
+  async streamChat(req: ChatRequest, cb: StreamCallbacks): Promise<void> {
+    const contents = mapMessages(req.messages, req.images, req.mediaResolution ?? this.defaultMediaResolution);
+
+    const stream = await (this.client.models as any).generateContentStream({
+      model: this.model,
+      contents,
+      generationConfig: {
+        temperature: req.temperature ?? 1.0,
+        maxOutputTokens: req.maxTokens,
+        ...(req.thinkingLevel ? { thinkingLevel: req.thinkingLevel } : { thinkingLevel: this.defaultThinkingLevel }),
+      },
+      tools: mapTools(req.tools),
+    });
+
+    try {
+      for await (const chunk of stream.stream) {
+        const text = chunk?.text ?? '';
+        if (text) cb.onText(text);
+
+        // Tool calls can also appear during streaming
+        const cand = (chunk as any).candidates?.[0];
+        if (cand?.content?.parts) {
+          for (const p of cand.content.parts) {
+            if (p.functionCall && cb.onToolCall) {
+              cb.onToolCall(p.functionCall.name, p.functionCall.args ?? {});
+            }
+          }
+        }
+      }
+      cb.onEnd && cb.onEnd();
+    } catch (err: any) {
+      cb.onError && cb.onError(err);
+      throw err;
+    }
+  }
+}
+
+export default Gemini3Provider;
