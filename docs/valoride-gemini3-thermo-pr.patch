diff --git a/webview-ui/src/components/TaskThermometer.tsx b/webview-ui/src/components/TaskThermometer.tsx
new file mode 100644
index 0000000..a4b3efe
--- /dev/null
+++ b/webview-ui/src/components/TaskThermometer.tsx
@@ -0,0 +1,162 @@
+import React from 'react';
+import '../styles/thermometer.css';
+
+export type Phase = 'PLAN' | 'ACT' | 'EDIT' | 'RUN' | 'VERIFY' | 'DONE';
+
+export interface ThermometerProps {
+  phase: Phase;
+  ratio?: number; // 0..1 for fine-grained fill within a segment
+}
+
+const ORDER: Phase[] = ['PLAN', 'ACT', 'EDIT', 'RUN', 'VERIFY', 'DONE'];
+
+export default function TaskThermometer({ phase, ratio = 0 }: ThermometerProps) {
+  const activeIndex = Math.max(0, ORDER.indexOf(phase));
+  const progressPct = (activeIndex / (ORDER.length - 1)) * 100;
+
+  return (
+    <div className="thermo-wrap" title={`Task phase: ${phase}`}>
+      <div className="thermo-labels">
+        {ORDER.map((p, i) => (
+          <span key={p} className={`thermo-label ${i <= activeIndex ? 'on' : ''}`}>{p}</span>
+        ))}
+      </div>
+
+      <div className="thermo-bar">
+        <div
+          className="thermo-fill"
+          style={{ width: `calc(${progressPct}% + ${ratio * (100 / (ORDER.length - 1))}%)` }}
+        />
+      </div>
+    </div>
+  );
+}
diff --git a/webview-ui/src/components/TaskHeader.tsx b/webview-ui/src/components/TaskHeader.tsx
index 30a1c9f..f1ad2c4 100644
--- a/webview-ui/src/components/TaskHeader.tsx
+++ b/webview-ui/src/components/TaskHeader.tsx
@@ -1,9 +1,34 @@
 import React from 'react';
 // ...other imports
+import TaskThermometer, { Phase } from './TaskThermometer';
 
 export default function TaskHeader(props: any) {
   const { task } = props;
+
+  const phase: Phase = ((): Phase => {
+    switch (task?.state) {
+      case 'planning': return 'PLAN';
+      case 'executing': return 'ACT';
+      case 'editing': return 'EDIT';
+      case 'running': return 'RUN';
+      case 'verifying': return 'VERIFY';
+      case 'done': return 'DONE';
+      default: return 'PLAN';
+    }
+  })();
+
   return (
     <div className="task-header">
       <h3>{task?.title ?? 'Task'}</h3>
+      <TaskThermometer phase={phase} />
     </div>
   );
 }
diff --git a/webview-ui/src/styles/thermometer.css b/webview-ui/src/styles/thermometer.css
new file mode 100644
index 0000000..16f24be
--- /dev/null
+++ b/webview-ui/src/styles/thermometer.css
@@ -0,0 +1,116 @@
+:root {
+  --thermo-bg: var(--vscode-editorWidget-background, #1e1e1e);
+  --thermo-fill: var(--vscode-terminal-ansiGreen, #3fb950);
+  --thermo-border: var(--vscode-editorWidget-border, #3c3c3c);
+  --thermo-text: var(--vscode-foreground, #cccccc);
+  --thermo-text-on: var(--vscode-editor-foreground, #ffffff);
+}
+
+.thermo-wrap {
+  display: flex;
+  flex-direction: column;
+  gap: 6px;
+  padding: 6px 0;
+}
+
+.thermo-labels {
+  display: flex;
+  justify-content: space-between;
+  font-size: 11px;
+  user-select: none;
+}
+
+.thermo-label {
+  color: var(--thermo-text);
+  letter-spacing: 0.3px;
+}
+
+.thermo-label.on {
+  color: var(--thermo-text-on);
+  font-weight: 600;
+}
+
+.thermo-bar {
+  position: relative;
+  height: 10px;
+  border-radius: 999px;
+  background: linear-gradient(180deg, rgba(255,255,255,0.06), rgba(0,0,0,0.06)),
+              var(--thermo-bg);
+  border: 1px solid var(--thermo-border);
+  overflow: hidden;
+}
+
+.thermo-fill {
+  position: absolute;
+  left: 0;
+  top: 0;
+  height: 100%;
+  border-radius: 999px;
+  background: linear-gradient(90deg,
+    rgba(63,185,80,0.05) 0%,
+    rgba(63,185,80,0.25) 15%,
+    rgba(63,185,80,0.5) 35%,
+    rgba(63,185,80,0.9) 100%
+  ), var(--thermo-fill);
+  transition: width 180ms ease-out;
+}
+
+/* High contrast support */
+@media (prefers-contrast: more) {
+  .thermo-fill { filter: saturate(1.2) brightness(1.05); }
+}
+
+/* Light theme tweak */
+@media (prefers-color-scheme: light) {
+  :root {
+    --thermo-bg: #f5f5f5;
+    --thermo-border: #d0d0d0;
+    --thermo-text: #666;
+    --thermo-text-on: #111;
+  }
+}
