        "tasks": [
          {
            "id": "task-fetch-leads",
            "name": "Fetch Leads",
            "description": "Query database for active leads",
            "workflowId": "wf-email-notif-lead",
            "taskOrder": 1,
            "modules": [
              {
                "id": "mod-db-poller",
                "name": "DatabasePoller",
                "className": "com.valkyrlabs.workflow.modules.database.DatabasePollerModule",
                "moduleType": "DatabasePoller",
                "status": "ready",
                "moduleData": "{\"source_path\": \"leads\", \"output_field\": \"fetchedLeads\", \"query\": \"SELECT id, email, firstName, lastName, company FROM leads WHERE status = 'active' AND created_at > NOW() - INTERVAL 7 DAY LIMIT 1000\"}",
                "config": {}
              }
            ]
          },
          {
            "id": "task-enrich-api",
            "name": "Enrich Via API",
            "description": "Call external enrichment API for each lead",
            "workflowId": "wf-email-notif-lead",
            "taskOrder": 2,
            "modules": [
              {
                "id": "mod-rest-generic",
                "name": "RestGeneric",
                "className": "com.valkyrlabs.workflow.modules.rest.RestGenericModule",
                "moduleType": "RestGeneric",
                "status": "ready",
                "moduleData": "{\"operationId\": \"enrichLead\", \"params\": {\"email\": \"{{lead.email}}\"}, \"body\": {}, \"headers\": {\"Authorization\": \"Bearer {{enrichmentApiKey}}\"}}",
                "integrationAccount": {
                  "id": "ia-enrichment-api",
                  "accountName": "ENRICHMENT_API",
                  "apiKey": "***",
                  "status": "ready",
                  "verified": true
                },
                "config": {
                  "openapi_url": "https://api.enrichment-provider.com/openapi.yaml"
                }
              }
            ]
          },
          {
            "id": "task-validate",
            "name": "Validate Data",
            "description": "Validate lead data against schema",
            "workflowId": "wf-email-notif-lead",
            "taskOrder": 3,
            "modules": [
              {
                "id": "mod-validation",
                "name": "DataValidation",
                "className": "com.valkyrlabs.workflow.modules.quality.DataValidationModule",
                "moduleType": "DataValidation",
                "status": "ready",
                "moduleData": "{\"source_path\": \"state.enrichedLeads\", \"output_field\": \"validationResult\", \"mode\": \"collect\", \"schema\": {\"type\": \"object\", \"required\": [\"email\", \"firstName\", \"lastName\"], \"properties\": {\"email\": {\"type\": \"string\", \"format\": \"email\"}, \"firstName\": {\"type\": \"string\", \"minLength\": 1, \"maxLength\": 100}, \"lastName\": {\"type\": \"string\", \"minLength\": 1, \"maxLength\": 100}, \"company\": {\"type\": \"string\", \"maxLength\": 255}, \"enrichmentScore\": {\"type\": \"number\", \"minimum\": 0, \"maximum\": 100}}}}",
                "config": {}
              }
            ]
          },
          {
            "id": "task-filter-prefs",
            "name": "Filter Preferences",
            "description": "Filter leads by opt-in status and consent",
            "workflowId": "wf-email-notif-lead",
            "taskOrder": 4,
            "modules": [
              {
                "id": "mod-pref-filter",
                "name": "PreferenceFilter",
                "className": "com.valkyrlabs.workflow.modules.valkyr.PreferenceFilterModule",
                "moduleType": "PreferenceFilter",
                "status": "ready",
                "moduleData": "{\"defaultOptIn\": false}",
                "config": {}
              }
            ]
          },
          {
            "id": "task-prepare-email",
            "name": "Prepare Email",
            "description": "Merge template with lead data",
            "workflowId": "wf-email-notif-lead",
            "taskOrder": 5,
            "modules": [
              {
                "id": "mod-template-merge",
                "name": "TemplateMerge",
                "className": "com.valkyrlabs.workflow.modules.transform.TemplateMergeModule",
                "moduleType": "TemplateMerge",
                "status": "ready",
                "moduleData": "{\"format\": \"html\", \"defaultSubject\": \"Hello {{firstName}}, check out what's new!\"}",
                "config": {}
              }
            ]
          },
          {
            "id": "task-send-email",
            "name": "Send Email",
            "description": "Send email via Mailtrap",
            "workflowId": "wf-email-notif-lead",
            "taskOrder": 6,
            "modules": [
              {
                "id": "mod-mailtrap-send",
                "name": "MailtrapSend",
                "className": "com.valkyrlabs.workflow.modules.email.MailtrapSendModule",
                "moduleType": "MailtrapSend",
                "status": "ready",
                "moduleData": "{}",
                "integrationAccount": {
                  "id": "ia-mailtrap",
                  "accountName": "MAILTRAP_PRIMARY",
                  "apiKey": "***",
                  "status": "ready",
                  "verified": true
                },
                "config": {
                  "emailAccount": "MAILTRAP_PRIMARY",
                  "from": "notifications@valkyr.io",
                  "cc": "",
                  "bcc": "",
                  "replyTo": "support@valkyr.io"
                }
              }
            ]
          },
          {
            "id": "task-stats",
            "name": "Collect Statistics",
            "description": "Aggregate execution metrics",
            "workflowId": "wf-email-notif-lead",
            "taskOrder": 7,
            "modules": [
              {
                "id": "mod-stats-collector",
                "name": "StatisticsCollector",
                "className": "com.valkyrlabs.workflow.modules.analytics.StatisticsCollectorExecModule",
                "moduleType": "StatisticsCollectorExecModule",
                "status": "ready",
                "moduleData": "{}",
                "config": {}
              }
            ]
          }
        ]
      }
