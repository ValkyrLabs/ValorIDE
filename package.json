{
  "name": "valoride-dev",
  "displayName": "ValorIDE",
  "description": "Agentic coding right in your IDE, capable of creating/editing files, running commands, using the browser, and more with your permission every step of the way.",
  "version": "3.20.845",
  "icon": "assets/icons/icon.png",
  "pricing": "Free",
  "galleryBanner": {
    "color": "#617A91",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.103.0"
  },
  "author": {
    "name": "Valkyr Labs Inc"
  },
  "license": "Apache-2.0",
  "publisher": "ValkyrLabsInc",
  "repository": {
    "type": "git",
    "url": "https://github.com/valkyrlabs/valoride"
  },
  "homepage": "https://valkyrlabs.com",
  "categories": [
    "AI",
    "Chat",
    "Programming Languages",
    "Education",
    "Snippets",
    "Testing"
  ],
  "keywords": [
    "valoride",
    "claude",
    "dev",
    "mcp",
    "openrouter",
    "coding",
    "agent",
    "autonomous",
    "chatgpt",
    "sonnet",
    "opus",
    "ai",
    "llama"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onViewContainer:valoride-activitybar"
  ],
  "main": "./dist/extension.js",
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "valoride-activitybar",
          "title": "Valor IDE",
          "icon": "assets/icons/icon.svg"
        }
      ]
    },
    "views": {
      "valoride-activitybar": [
        {
          "type": "webview",
          "id": "valoride-dev.SidebarProvider",
          "name": "ValorIDE",
          "icon": "assets/icons/icon.svg"
        },
        {
          "type": "tree",
          "id": "valoride-dev.ProjectsView",
          "name": "Projects",
          "icon": "assets/icons/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "valoride.plusButtonClicked",
        "title": "New Task",
        "icon": "$(add)"
      },
      {
        "command": "valoride.accountButtonClicked",
        "title": "Account Settings",
        "icon": "$(shield)"
      },
      {
        "command": "valoride.serverConsoleButtonClicked",
        "title": "Server Console",
        "icon": "$(debug-console)"
      },
      {
        "command": "valoride.mcpButtonClicked",
        "title": "MCP Servers",
        "icon": "$(server)"
      },
      {
        "command": "valoride.historyButtonClicked",
        "title": "History",
        "icon": "$(history)"
      },
      {
        "command": "valoride.popoutButtonClicked",
        "title": "Open in Editor",
        "icon": "$(link-external)"
      },
      {
        "command": "valoride.settingsButtonClicked",
        "title": "Settings",
        "icon": "$(settings-gear)"
      },
      {
        "command": "valoride.openInNewTab",
        "title": "Open In New Tab",
        "category": "ValorIDE"
      },
      {
        "command": "valoride.diagnostics",
        "title": "Show Diagnostics",
        "category": "ValorIDE"
      },
      {
        "command": "valoride.graymatter.openMemoryPanel",
        "title": "Open GrayMatter Memory Browser",
        "category": "ValorIDE",
        "icon": "$(database)"
      },
      {
        "command": "valoride.graymatter.signIn",
        "title": "Sign In To GrayMatter",
        "category": "ValorIDE",
        "icon": "$(sign-in)"
      },
      {
        "command": "valoride.graymatter.rotateToken",
        "title": "Rotate GrayMatter Token",
        "category": "ValorIDE",
        "icon": "$(key)"
      },
      {
        "command": "valoride.fixLayout",
        "title": "Reset Layout",
        "category": "ValorIDE",
        "icon": "$(refresh)"
      },
      {
        "command": "valoride.openUrlInEditor",
        "title": "Open URL In Editor",
        "category": "ValorIDE"
      },
      {
        "command": "valoride.addThorAliasesFromFolder",
        "title": "Add @ Aliases From Folder",
        "category": "ValorIDE"
      },
      {
        "command": "valoride.projectActions",
        "title": "ValorIDE: Project Actions",
        "category": "ValorIDE"
      },
      {
        "command": "valoride.projects.refresh",
        "title": "Refresh Projects",
        "category": "ValorIDE",
        "icon": "$(refresh)"
      },
      {
        "command": "valoride.projects.build",
        "title": "Build Project",
        "category": "ValorIDE",
        "icon": "$(tools)"
      },
      {
        "command": "valoride.projects.run",
        "title": "Run Project",
        "category": "ValorIDE",
        "icon": "$(play)"
      },
      {
        "command": "valoride.projects.openInWindow",
        "title": "Open in New Window",
        "category": "ValorIDE",
        "icon": "$(link-external)"
      },
      {
        "command": "valoride.projects.openTerminal",
        "title": "Open Terminal Here",
        "category": "ValorIDE",
        "icon": "$(terminal)"
      },
      {
        "command": "valoride.projects.openReadme",
        "title": "Open README",
        "category": "ValorIDE",
        "icon": "$(book)"
      },
      {
        "command": "valoride.projects.reveal",
        "title": "Reveal in Explorer",
        "category": "ValorIDE",
        "icon": "$(folder)"
      },
      {
        "command": "valoride.projects.copyPath",
        "title": "Copy Folder Path",
        "category": "ValorIDE",
        "icon": "$(clippy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "valoride.plusButtonClicked",
          "group": "navigation@1",
          "when": "view == valoride-dev.SidebarProvider"
        },
        {
          "command": "valoride.mcpButtonClicked",
          "group": "navigation@2",
          "when": "view == valoride-dev.SidebarProvider"
        },
        {
          "command": "valoride.historyButtonClicked",
          "group": "navigation@3",
          "when": "view == valoride-dev.SidebarProvider"
        },
        {
          "command": "valoride.popoutButtonClicked",
          "group": "navigation@4",
          "when": "view == valoride-dev.SidebarProvider"
        },
        {
          "command": "valoride.settingsButtonClicked",
          "group": "navigation@5",
          "when": "view == valoride-dev.SidebarProvider"
        },
        {
          "command": "valoride.accountButtonClicked",
          "group": "navigation@6",
          "when": "view == valoride-dev.SidebarProvider"
        },
        {
          "command": "valoride.projects.refresh",
          "group": "navigation@1",
          "when": "view == valoride-dev.ProjectsView"
        }
      ],
      "view/item/context": [
        {
          "command": "valoride.projects.openInWindow",
          "when": "view == valoride-dev.ProjectsView && viewItem == thorProject",
          "group": "inline@1"
        },
        {
          "command": "valoride.projects.build",
          "when": "view == valoride-dev.ProjectsView && viewItem == thorProject",
          "group": "inline@2"
        },
        {
          "command": "valoride.projects.run",
          "when": "view == valoride-dev.ProjectsView && viewItem == thorProject",
          "group": "inline@3"
        },
        {
          "command": "valoride.projects.openTerminal",
          "when": "view == valoride-dev.ProjectsView && viewItem == thorProject",
          "group": "inline@4"
        },
        {
          "command": "valoride.projects.openReadme",
          "when": "view == valoride-dev.ProjectsView && viewItem == thorProject",
          "group": "inline@5"
        },
        {
          "command": "valoride.projects.reveal",
          "when": "view == valoride-dev.ProjectsView && viewItem == thorProject",
          "group": "2_navigation@1"
        },
        {
          "command": "valoride.projects.copyPath",
          "when": "view == valoride-dev.ProjectsView && viewItem == thorProject",
          "group": "2_navigation@2"
        },
        {
          "command": "valoride.addThorAliasesFromFolder",
          "when": "view == valoride-dev.ProjectsView && viewItem == thorProject",
          "group": "3_edit@1"
        }
      ],
      "explorer/context": [
        {
          "when": "explorerResourceIsFolder == true",
          "command": "valoride.addThorAliasesFromFolder",
          "group": "navigation@9"
        },
        {
          "when": "explorerResourceIsFolder == true && resourceFilename =~ /^v\\d+\\./",
          "command": "valoride.projectActions",
          "group": "navigation@1"
        }
      ],
      "editor/title": [
        {
          "command": "valoride.plusButtonClicked",
          "group": "navigation@1",
          "when": "valoride.isValorIDETab"
        },
        {
          "command": "valoride.mcpButtonClicked",
          "group": "navigation@2",
          "when": "valoride.isValorIDETab"
        },
        {
          "command": "valoride.historyButtonClicked",
          "group": "navigation@3",
          "when": "valoride.isValorIDETab"
        },
        {
          "command": "valoride.settingsButtonClicked",
          "group": "navigation@4",
          "when": "valoride.isValorIDETab"
        },
        {
          "command": "valoride.accountButtonClicked",
          "group": "navigation@5",
          "when": "valoride.isValorIDETab"
        }
      ]
    },
    "configuration": {
      "title": "ValorIDE",
      "properties": {
        "valoride.advanced.fileProcessing.warnLargeFiles": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Show warnings for large files in DiffViewProvider."
        },
        "valoride.advanced.fileProcessing.largeFileThreshold": {
          "type": "number",
          "default": 20480,
          "markdownDescription": "Bytes threshold to show informational warning for large files.",
          "minimum": 1024
        },
        "valoride.advanced.fileProcessing.maxFileSize": {
          "type": "number",
          "default": 512000,
          "markdownDescription": "Maximum file size in bytes before showing blocking warning in DiffViewProvider.",
          "minimum": 1024
        },
        "valoride.advanced.budgetAlerts.depletedThreshold": {
          "type": "number",
          "default": 0,
          "markdownDescription": "Effective balance (USD) at or below which 'Budget Depleted' alert shows.",
          "minimum": 0
        },
        "valoride.advanced.budgetAlerts.criticalThreshold": {
          "type": "number",
          "default": 1,
          "markdownDescription": "Effective balance (USD) at or below which 'Critical Budget Alert' shows.",
          "minimum": 0
        },
        "valoride.advanced.budgetAlerts.lowThreshold": {
          "type": "number",
          "default": 5,
          "markdownDescription": "Effective balance (USD) at or below which 'Low Budget Warning' shows.",
          "minimum": 0
        },
        "valoride.advanced.budgetAlerts.alertThreshold": {
          "type": "number",
          "default": 10,
          "markdownDescription": "Effective balance (USD) at or below which 'Budget Alert' shows.",
          "minimum": 0
        },
        "valoride.advanced.thorapi.outputFolder": {
          "type": "string",
          "default": "thorapi",
          "markdownDescription": "Relative (workspace) or absolute path where ThorAPI downloads and generated projects are stored."
        },
        "valoride.advanced.debugging.showPsrResultsReport": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "When enabled, ValorIDE prints the full precision_search_and_replace result report after each edit."
        },
        "valoride.valkyrai.host": {
          "type": "string",
          "default": "https://api-0.valkyrlabs.com/v1",
          "markdownDescription": "Base URL used for ValkyrAI API calls (synced across machines).",
          "scope": "application"
        },
        "valoride.graymatter.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Enable GrayMatter cloud memory integration."
        },
        "valoride.graymatter.mcpEnabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Register GrayMatter as a built-in MCP server inside ValorIDE."
        },
        "valoride.graymatter.autoCapture": {
          "type": "string",
          "enum": [
            "all",
            "decisions",
            "off"
          ],
          "default": "decisions",
          "markdownDescription": "Controls which events are automatically saved to GrayMatter."
        },
        "valoride.graymatter.defaultWriteScope": {
          "type": "string",
          "enum": [
            "project",
            "organization",
            "user"
          ],
          "default": "project",
          "markdownDescription": "Default scope for automatic GrayMatter memory writes."
        },
        "valoride.graymatter.contextMaxTokens": {
          "type": "number",
          "default": 2000,
          "minimum": 200,
          "markdownDescription": "Maximum tokens allocated to GrayMatter remembered context in system prompts."
        },
        "valoride.graymatter.queryTimeoutMs": {
          "type": "number",
          "default": 3000,
          "minimum": 250,
          "markdownDescription": "Timeout in milliseconds for GrayMatter context queries."
        },
        "valoride.P2P.turnServers": {
          "type": "array",
          "markdownDescription": "List of ICE/TURN servers for P2P (RTCConfiguration. Each entry may be a string URL or an object with { urls, username, credential }).",
          "items": {
            "oneOf": [
              {
                "type": "string",
                "description": "stun:example.org or turn:example.org:3478"
              },
              {
                "type": "object",
                "properties": {
                  "urls": {
                    "type": [
                      "string",
                      "array"
                    ],
                    "description": "ICE server URLs"
                  },
                  "username": {
                    "type": "string"
                  },
                  "credential": {
                    "type": "string"
                  }
                },
                "required": [
                  "urls"
                ]
              }
            ]
          },
          "default": [
            "stun:stun.l.google.com:19302"
          ]
        },
        "valoride.P2P.discovery.bonjour": {
          "type": "boolean",
          "markdownDescription": "Enable experimental Bonjour/mDNS peer discovery for local network rendezvous (requires reload).",
          "default": false
        },
        "valoride.vsCodeLmModelSelector": {
          "type": "object",
          "properties": {
            "vendor": {
              "type": "string",
              "description": "The vendor of the language model (e.g. copilot)"
            },
            "family": {
              "type": "string",
              "description": "The family of the language model (e.g. gpt-4)"
            }
          },
          "description": "Settings for VSCode Language Model API"
        },
        "valoride.mcp.mode": {
          "type": "string",
          "enum": [
            "full",
            "server-use-only",
            "off"
          ],
          "enumDescriptions": [
            "Enable all MCP functionality (server use and build instructions)",
            "Enable MCP server use only (excludes instructions about building MCP servers)",
            "Disable all MCP functionality"
          ],
          "default": "full",
          "description": "Controls MCP inclusion in prompts, reduces token usage if you only need access to certain functionality."
        },
        "valoride.enableCheckpoints": {
          "type": "boolean",
          "default": true,
          "description": "Enables extension to save checkpoints of workspace throughout the task."
        },
        "valoride.disableBrowserTool": {
          "type": "boolean",
          "default": false,
          "description": "Disables extension from spawning browser session."
        },
        "valoride.modelSettings.o3Mini.reasoningEffort": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "default": "medium",
          "description": "Controls the reasoning effort when using the o3-mini model. Higher values may result in more thorough but slower responses."
        },
        "valoride.chromeExecutablePath": {
          "type": "string",
          "default": null,
          "description": "Path to Chrome executable for browser use functionality. If not set, the extension will attempt to find or download it automatically."
        }
      }
    }
  },
  "scripts": {
    "webview-errors": "node ./scripts/webview_error_server.js",
    "map-source": "node ./scripts/map_source.js",
    "capture-console": "node ./scripts/capture_console.js",
    "build": "node esbuild.js",
    "build:full": "npm run compile",
    "build:release": "npm run format:fix && npm install && tsc && npm run v",
    "build-staging": "build --mode staging",
    "build-prod": "build --mode prod",
    "package:staging": "npm run build:webview:staging && npm run check-types && npm run lint && node esbuild.js --production",
    "package:prod": "npm run build:webview:prod && npm run check-types && npm run lint && node esbuild.js --production",
    "v": "NODE_OPTIONS= node increment-version.js && NODE_OPTIONS= vsce package --no-yarn --no-dependencies",
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run build:webview && npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p ./tsconfig.test.json --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "NODE_OPTIONS=--max-old-space-size=8192 tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "vscode-test",
    "install:all": "npm install && npm --prefix webview-ui install",
    "start:webview": "npm --prefix webview-ui run dev",
    "build:webview": "npm --prefix webview-ui run build && node scripts/sync-webview-build.js",
    "copy:webview": "node scripts/sync-webview-build.js",
    "sync:thorapi": "node scripts/sync-thorapi-from-valkyrai.mjs",
    "test:webview": "npm --prefix webview-ui run test",
    "publish:marketplace": "NODE_OPTIONS= vsce publish --no-yarn --no-dependencies && ovsx publish",
    "publish:marketplace:prerelease": "NODE_OPTIONS= vsce publish --pre-release --no-yarn --no-dependencies && ovsx publish --pre-release",
    "prepare": "husky",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "package:audit": "node scripts/audit-vsix-package.mjs",
    "test:package-audit": "node --test scripts/audit-vsix-package.test.mjs",
    "package:vsix": "npm run package && npx --yes @vscode/vsce package --no-yarn --no-dependencies && npm run package:audit"
  },
  "devDependencies": {
    "@ant-design/icons": "6.1.0",
    "@changesets/cli": "2.29.6",
    "@testing-library/react": "16.3.0",
    "@types/adm-zip": "0.5.7",
    "@types/chai": "5.2.2",
    "@types/diff": "5.2.3",
    "@types/jest": "29.5.14",
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.11",
    "@types/should": "11.2.0",
    "@types/vscode": "1.103.0",
    "@typescript-eslint/eslint-plugin": "8.41.0",
    "@typescript-eslint/parser": "8.41.0",
    "@vscode/test-cli": "0.0.10",
    "@vscode/test-electron": "2.5.2",
    "chai": "4.5.0",
    "esbuild": "0.25.9",
    "eslint": "9.34.0",
