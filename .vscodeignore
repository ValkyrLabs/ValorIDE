# Exclude version control and config
.git/
.gitignore
.husky/
.worktrees/
.vscode/
.DS_Store
.valoride
ValorIDE_docs/

# ignore caches and build outputs
**/.cache/**
**/.turbo/**
**/.vite/**
**/coverage/**
**/node_modules/**
**/*.log
**/*.map

# Exclude source, tests, docs, configs, and build scripts
src/
test/
tests/
__tests__/
docs/
evals/
*.ts
*.tsx
*.jsx
*.test.*
*.spec.*
tsconfig.json
tsconfig.*.json
esbuild.js
vite.config.*
eslint.config.*
*.log
*.lock
*.md
*.markdown
*.vsix
out/
webview-ui/
packages/*/node_modules/
packages/*/dist/
packages/*/out/

# Exclude other common unnecessary files
*.swp
*.swo
*.bak
*.tmp

# Include only the built output and essential files
!dist/
!extension.js
!package.json
!README.md
!LICENSE
!assets/
