{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true, // Add this line
    "baseUrl": ".",
    "paths": {
      "@thorapi/*": [
        "src/*"
      ],
      "@shared/*": [
        "../src/shared/*"
      ],
      "@thorapi/*": [
        "src//*"
      ],
      "@valkyr/component-library/*": [
        "src/components/*"
      ],
      "@utils/*": [
        "../src/utils/*"
      ],
      "@utils/serverValkyraiHost": [
        "src/utils/serverValkyraiHost.ts"
      ],
      "@thorapi/redux/services/*": [
        "src//redux/services/*"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "setupTests.js",
    "matchMedia.js"
  ]
}