{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true, // Add this line
    "baseUrl": ".",
    "paths": {
      "@thorapi/model": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/model/index.ts"
      ],
      "@thorapi/model/*": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/model/*"
      ],
      "@thorapi/src": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/src/index.ts"
      ],
      "@thorapi/redux": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/redux"
      ],
      "@thorapi/redux/*": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/redux/*"
      ],
      "@thorapi/redux/services": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/redux/services/index.ts"
      ],
      "@thorapi/redux/services/*": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/redux/services/*",
        "src/redux/services/*"
      ],
      "@thorapi/api": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/api/index.ts"
      ],
      "@thorapi/api/*": [
        "../../ValkyrAI/web/typescript/valkyr_labs_com/src/thorapi/api/*"
      ],
      "@thorapi/*": ["src/*"],
      "@valkyrai/openapi-designer": [
        "../../ValkyrAI/packages/component-library/src/openapi-designer"
      ],
      "@valkyrai/openapi-designer/*": [
        "../../ValkyrAI/packages/component-library/src/openapi-designer/*"
      ],
      "@shared/*": ["../src/shared/*"],
      "@valkyr/component-library/*": ["src/components/*"],
      "@utils/*": ["src/utils/*", "../src/utils/*"],
      "@utils/serverValkyraiHost": ["src/utils/serverValkyraiHost.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.spec.ts", "src/thorapi", "setupTests.js", "matchMedia.js"]
}
