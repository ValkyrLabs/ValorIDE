{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true, // Add this line
    "baseUrl": ".",
    "paths": {
      "@thorapi/model": ["src/thorapi/model/index.ts"],
      "@thorapi/model/*": ["src/thorapi/model/*"],
      "@thorapi/src": ["src/thorapi/src/index.ts"],
      "@thorapi/redux/*": ["src/thorapi/redux/*"],
      "@thorapi/redux/services": ["src/thorapi/redux/services/index.ts"],
      "@thorapi/redux/services/*": [
        "src/thorapi/redux/services/*",
        "src/redux/services/*"
      ],
      "@thorapi/api": ["src/thorapi/api/index.ts"],
      "@thorapi/api/*": ["src/thorapi/api/*"],
      "@thorapi/*": ["src/*"],
      "@shared/*": ["../src/shared/*"],
      "@valkyr/component-library/*": ["src/components/*"],
      "@utils/*": ["src/utils/*", "../src/utils/*"],
      "@utils/serverValkyraiHost": ["src/utils/serverValkyraiHost.ts"],
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "setupTests.js",
    "matchMedia.js"
  ]
}
